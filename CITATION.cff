        given-names: "Julien"
      - family-names: "Pallier"
        given-names: "Christophe"
    title: "UniPseudo: A Universal Pseudoword Generator"
    journal: Quarterly Journal of Experimental Psychology
    year: 2023
    doi: 10.1177/17470218231164373
